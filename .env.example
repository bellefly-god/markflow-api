# MarkFlow API Configuration
# Copy this to .env and fill in your values

# App
APP_NAME=MarkFlow API
APP_VERSION=1.0.0
DEBUG=false
API_PREFIX=/v1

# Server
HOST=0.0.0.0
PORT=8000

# Security
SECRET_KEY=your-super-secret-key-change-in-production
ALLOWED_ORIGINS=["*"]

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=3600

# File Upload
MAX_FILE_SIZE=52428800
UPLOAD_DIR=./uploads

# Redis (optional, for rate limiting & caching)
# REDIS_URL=redis://localhost:6379

# OpenAI / LLM (required for AI features)
OPENAI_API_KEY=your-openai-api-key
# OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# Azure Document Intelligence (optional)
# AZURE_DOC_INTEL_ENDPOINT=https://your-resource.cognitiveservices.azure.com/

# Pricing (for OpenRouter)
PRICE_PER_1K_TOKENS_INPUT=0.001
PRICE_PER_1K_TOKENS_OUTPUT=0.002
PRICE_PER_CONVERSION=0.01

# Prometheus Metrics
ENABLE_METRICS=true
METRICS_PORT=9090
