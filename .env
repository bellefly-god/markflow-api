# MarkFlow API Configuration

# App
APP_NAME=MarkFlow API
APP_VERSION=1.0.0
DEBUG=true
API_PREFIX=/v1

# Server
HOST=0.0.0.0
PORT=8000

# Security
SECRET_KEY=markflow-dev-secret-key-change-in-production
ALLOWED_ORIGINS=["*"]

# File Upload
MAX_FILE_SIZE=52428800
UPLOAD_DIR=./uploads

# OpenAI (optional - for AI features)
# OPENAI_API_KEY=your-key-here
LLM_MODEL=gpt-4o-mini
